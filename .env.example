# Copy this file to .env and source it before running Terragrunt with LocalStack.
# The .env file is gitignored — never commit real credentials.
#
#   cp .env.example .env
#   source .env

# Redirects all AWS API calls to LocalStack (http://localhost:4566).
# Leave unset to target real AWS using ~/.aws/credentials.
export LOCALSTACK_ENDPOINT=http://localhost:4566

# LocalStack auth token — required to use the cloud dashboard and Pro features.
# Get yours at https://app.localstack.cloud/workspace/auth-tokens
export LOCALSTACK_AUTH_TOKEN=ls-LAkaDIWe-comU-coSI-sOrU-17891386b556

# LocalStack accepts any non-empty value for credentials.
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=us-east-1
